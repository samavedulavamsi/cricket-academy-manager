generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ACADEMY_ADMIN
  HEAD_COACH
  ASSISTANT_COACH
  MANAGER
  ACCOUNTANT
  PARENT
  PLAYER
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum PermissionKey {
  MANAGE_ACADEMY
  MANAGE_COACHES
  MANAGE_ROLE_PERMISSIONS
  MANAGE_PLAYERS
  MANAGE_ATTENDANCE
  MANAGE_FEES
  VIEW_FINANCIALS
  VIEW_REPORTS
  MANAGE_MATCHES
  MANAGE_TOURNAMENTS
  VIEW_PARENT_PORTAL
  VIEW_SPORTS_NEWS
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PlayingRole {
  BATSMAN
  BOWLER
  ALL_ROUNDER
  WICKET_KEEPER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
}

enum FeeStatus {
  PAID
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
}

enum MatchResult {
  WON
  LOST
  DRAW
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum AudienceType {
  ALL
  COACHES
  PARENTS
  PLAYERS
}

enum MediaAssetType {
  PHOTO
  VIDEO
  DOCUMENT
}

model Academy {
  id                  String                   @id @default(cuid())
  name                String
  logoUrl             String?
  address             String
  city                String
  state               String
  country             String
  mobileNumber        String
  email               String
  website             String?
  ownerName           String
  subscriptionPlan    SubscriptionPlan         @default(FREE)
  academyCode         String                   @unique
  subdomain           String?                  @unique
  timeZone            String                   @default("Asia/Kolkata")
  currency            String                   @default("INR")
  themeColor          String                   @default("#17834b")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  settings            AcademySettings?
  rolePermissions     RolePermission[]
  users               User[]
  players             Player[]
  pendingRegistrations PendingRegistration[]
  attendance          Attendance[]
  extraPractices      ExtraPractice[]
  feePayments         FeePayment[]
  performanceStats    PerformanceStat[]
  assessments         SkillAssessment[]
  matches             Match[]
  tournaments         Tournament[]
  matchPerformances   PlayerMatchPerformance[]
  coachInvitations    CoachInvitation[]
  passwordResetTokens PasswordResetToken[]
  coachFeedback       CoachFeedback[]
  notifications       Notification[]
  mediaAssets         MediaAsset[]
  downloads           DownloadResource[]
}

model AcademySettings {
  id                    String   @id @default(cuid())
  academyId             String   @unique
  dashboardTitle        String
  dashboardDescription  String
  registrationOpen      Boolean  @default(true)
  allowParentSelfSignup Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
}

model RolePermission {
  id         String        @id @default(cuid())
  academyId  String
  role       UserRole
  permission PermissionKey
  allowed    Boolean       @default(true)

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@unique([academyId, role, permission])
  @@index([academyId, role])
}

model User {
  id                String   @id @default(cuid())
  academyId         String
  name              String
  email             String
  passwordHash      String
  role              UserRole
  playerId          String?  @unique
  phone             String?
  profilePhotoUrl   String?
  title             String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  academy             Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player              Player?              @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sentInvitations     CoachInvitation[]    @relation("InvitationSender")
  passwordResetTokens PasswordResetToken[]
  coachFeedback       CoachFeedback[]      @relation("CoachFeedbackAuthor")

  @@unique([academyId, email])
  @@index([academyId, role])
}

model CoachInvitation {
  id          String       @id @default(cuid())
  academyId   String
  email       String
  phone       String?
  role        UserRole
  token       String       @unique
  message     String?
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  academy   Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([academyId, email])
  @@index([academyId, status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  academyId String
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([academyId, userId])
}

model Player {
  id                  String       @id @default(cuid())
  academyId           String
  playerCode          String
  fullName            String
  dateOfBirth         DateTime
  gender              Gender
  mobileNumber        String
  parentName          String
  parentContactNumber String
  address             String
  bloodGroup          String?
  emergencyContact    String
  playingRole         PlayingRole
  battingStyle        String
  bowlingStyle        String
  jerseyNumber        Int
  joiningDate         DateTime
  skillLevel          SkillLevel
  photoUrl            String?
  idProofUrl          String?
  monthlyFeeAmount    Int          @default(0)
  admissionFee        Int          @default(0)
  discount            Int          @default(0)
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  academy           Academy                  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  attendance        Attendance[]
  extraPractices    ExtraPractice[]
  feePayments       FeePayment[]
  performanceStats  PerformanceStat[]
  assessments       SkillAssessment[]
  matchPerformances PlayerMatchPerformance[]
  coachFeedback     CoachFeedback[]
  user              User?

  @@unique([academyId, playerCode])
  @@unique([academyId, jerseyNumber])
  @@index([academyId, fullName])
}

model PendingRegistration {
  id                  String             @id @default(cuid())
  academyId           String
  fullName            String
  dateOfBirth         DateTime
  gender              Gender
  mobileNumber        String
  parentName          String
  parentContactNumber String
  address             String
  bloodGroup          String?
  emergencyContact    String
  playingRole         PlayingRole
  battingStyle        String
  bowlingStyle        String
  jerseyNumber        Int?
  joiningDate         DateTime
  skillLevel          SkillLevel
  monthlyFeeAmount    Int                @default(0)
  admissionFee        Int                @default(0)
  discount            Int                @default(0)
  status              RegistrationStatus @default(PENDING)
  source              String             @default("GOOGLE_FORMS")
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId, status])
}

model Attendance {
  id            String           @id @default(cuid())
  academyId     String
  playerId      String
  date          DateTime
  morningStatus AttendanceStatus @default(ABSENT)
  eveningStatus AttendanceStatus @default(ABSENT)
  remarks       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([academyId, playerId, date])
  @@index([academyId, date])
}

model ExtraPractice {
  id           String   @id @default(cuid())
  academyId    String
  playerId     String
  date         DateTime
  practiceType String
  durationMins Int
  coachRemarks String?
  createdAt    DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([academyId, date])
}

model FeePayment {
  id            String        @id @default(cuid())
  academyId     String
  playerId      String
  dueDate       DateTime
  paidDate      DateTime?
  amountPaid    Int           @default(0)
  paymentMethod PaymentMethod
  receiptNumber String
  status        FeeStatus     @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([academyId, receiptNumber])
  @@index([academyId, dueDate])
  @@index([academyId, status])
}

model PerformanceStat {
  id                 String   @id @default(cuid())
  academyId          String
  playerId           String
  recordedAt         DateTime @default(now())
  matchesPlayed      Int      @default(0)
  innings            Int      @default(0)
  runsScored         Int      @default(0)
  highestScore       Int      @default(0)
  battingAverage     Float    @default(0)
  strikeRate         Float    @default(0)
  boundaries         Int      @default(0)
  fifties            Int      @default(0)
  hundreds           Int      @default(0)
  oversBowled        Float    @default(0)
  wickets            Int      @default(0)
  economy            Float    @default(0)
  bestBowlingFigures String?
  maidens            Int      @default(0)
  catches            Int      @default(0)
  runOuts            Int      @default(0)
  stumpings          Int      @default(0)

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([academyId, recordedAt])
}

model SkillAssessment {
  id              String   @id @default(cuid())
  academyId       String
  playerId        String
  assessmentMonth DateTime
  footwork        Int
  shotSelection   Int
  timing          Int
  powerHitting    Int
  line            Int
  length          Int
  paceSpin        Int
  swingSpin       Int
  speed           Int
  agility         Int
  endurance       Int
  strength        Int
  catching        Int
  throwing        Int
  reflexes        Int
  coachNotes      String?
  createdAt       DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([academyId, playerId, assessmentMonth])
}

model Match {
  id           String      @id @default(cuid())
  academyId    String
  tournamentId String?
  matchName    String
  opponentTeam String
  date         DateTime
  venue        String
  result       MatchResult
  createdAt    DateTime    @default(now())

  academy      Academy                  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  tournament   Tournament?              @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  performances PlayerMatchPerformance[]

  @@index([academyId, date])
}

model Tournament {
  id        String   @id @default(cuid())
  academyId String
  name      String
  season    String
  startDate DateTime
  endDate   DateTime?
  venue     String
  status    String   @default("UPCOMING")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  matches  Match[]

  @@index([academyId, startDate])
}

model PlayerMatchPerformance {
  id           String @id @default(cuid())
  academyId    String
  playerId     String
  matchId      String
  runs         Int    @default(0)
  balls        Int    @default(0)
  fours        Int    @default(0)
  sixes        Int    @default(0)
  overs        Float  @default(0)
  runsConceded Int    @default(0)
  wickets      Int    @default(0)
  catches      Int    @default(0)
  runOuts      Int    @default(0)

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([academyId, playerId, matchId])
}

model CoachFeedback {
  id        String   @id @default(cuid())
  academyId String
  playerId  String
  coachId   String
  title     String
  notes     String
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  coach   User    @relation("CoachFeedbackAuthor", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([academyId, playerId, createdAt])
}

model Notification {
  id        String       @id @default(cuid())
  academyId String
  title     String
  message   String
  audience  AudienceType @default(ALL)
  createdAt DateTime     @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId, audience, createdAt])
}

model MediaAsset {
  id         String         @id @default(cuid())
  academyId  String
  title      String
  type       MediaAssetType @default(PHOTO)
  previewUrl String
  createdAt  DateTime       @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId, createdAt])
}

model DownloadResource {
  id          String       @id @default(cuid())
  academyId   String
  title       String
  description String
  fileUrl     String
  audience    AudienceType @default(PARENTS)
  createdAt   DateTime     @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId, audience, createdAt])
}
